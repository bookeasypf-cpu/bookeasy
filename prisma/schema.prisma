generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// USERS & AUTHENTICATION
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  phone         String?
  image         String?
  role          String    @default("CLIENT")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  merchant      Merchant?
  bookings      Booking[]       @relation("ClientBookings")
  reviews       Review[]
  notifications Notification[]
  referralCode      String?        @unique
  xpTransactions XpTransaction[]
  xpRedemptions XpRedemption[]
  pushSubscriptions PushSubscription[]
  favorites         Favorite[]
  referralsSent     Referral[]     @relation("ReferralsSent")
  referralsReceived Referral[]     @relation("ReferralsReceived")
  patientNotes      PatientNote[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// MERCHANT / BUSINESS
// ─────────────────────────────────────────────

model Sector {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  icon      String?
  merchants Merchant[]

  @@map("sectors")
}

model Merchant {
  id           String   @id @default(cuid())
  userId       String   @unique
  businessName String
  description  String?
  phone        String?
  address      String?
  city         String?
  postalCode   String?
  latitude     Float?
  longitude    Float?
  coverImage   String?
  plan                  String   @default("FREE") // FREE or PRO
  stripeCustomerId      String?  @unique
  stripeSubscriptionId  String?
  planExpiresAt         DateTime?
  paymentPolicy     String   @default("NONE") // NONE, FLEXIBLE, ONLINE_ONLY
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sectorId     String
  sector       Sector          @relation(fields: [sectorId], references: [id])
  services     Service[]
  availability WeeklySchedule[]
  bookings     Booking[]       @relation("MerchantBookings")
  reviews        Review[]
  photos         MerchantPhoto[]
  blockedSlots   BlockedSlot[]
  xpRewards      XpReward[]
  xpTransactions XpTransaction[]
  xpPerBooking   Int             @default(10)
  giftCards      GiftCard[]
  favorites      Favorite[]
  patientNotes   PatientNote[]

  @@index([city])
  @@index([sectorId])
  @@map("merchants")
}

model MerchantPhoto {
  id         String   @id @default(cuid())
  merchantId String
  url        String
  caption    String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@map("merchant_photos")
}

// ─────────────────────────────────────────────
// SERVICES
// ─────────────────────────────────────────────

model Service {
  id          String   @id @default(cuid())
  merchantId  String
  name        String
  description String?
  duration    Int
  price       Float
  currency    String   @default("EUR")
  xpAmount    Int?     // XP personnalisé par service (null = utilise le défaut du commerçant)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  merchant Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([merchantId])
  @@map("services")
}

// ─────────────────────────────────────────────
// AVAILABILITY & SCHEDULING
// ─────────────────────────────────────────────

model WeeklySchedule {
  id         String  @id @default(cuid())
  merchantId String
  dayOfWeek  Int
  startTime  String
  endTime    String
  isActive   Boolean @default(true)

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([merchantId, dayOfWeek, startTime])
  @@index([merchantId])
  @@map("weekly_schedules")
}

model BlockedSlot {
  id         String   @id @default(cuid())
  merchantId String
  date       String
  startTime  String?
  endTime    String?
  reason     String?
  createdAt  DateTime @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId, date])
  @@map("blocked_slots")
}

// ─────────────────────────────────────────────
// BOOKINGS
// ─────────────────────────────────────────────

model Booking {
  id           String    @id @default(cuid())
  clientId     String
  merchantId   String
  serviceId    String
  date         String
  startTime    String
  endTime      String
  status       String    @default("PENDING")
  notes        String?
  totalPrice   Float
  cancelledAt  DateTime?
  cancelReason String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Payment fields
  paymentStatus    String?   // PENDING, PAID, FAILED, REFUNDED
  payzenOrderId    String?
  payzenTransId    String?
  amountPaid       Float?    // Amount charged via PayZen (XPF, after gift card)
  giftCardCode     String?
  giftCardAmount   Float?    // Gift card deduction (XPF)
  paymentExpiresAt DateTime?

  client         User            @relation("ClientBookings", fields: [clientId], references: [id])
  merchant       Merchant        @relation("MerchantBookings", fields: [merchantId], references: [id])
  service        Service         @relation(fields: [serviceId], references: [id])
  review         Review?
  xpTransactions XpTransaction[]

  @@index([clientId])
  @@index([merchantId, date])
  @@index([merchantId, date, startTime])
  @@index([status, paymentExpiresAt])
  @@map("bookings")
}

// ─────────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────────

model Review {
  id         String   @id @default(cuid())
  bookingId  String   @unique
  clientId   String
  merchantId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  booking  Booking  @relation(fields: [bookingId], references: [id])
  client   User     @relation(fields: [clientId], references: [id])
  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@index([merchantId])
  @@map("reviews")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  metadata  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// ─────────────────────────────────────────────
// XP / LOYALTY PROGRAM
// ─────────────────────────────────────────────

model XpTransaction {
  id         String   @id @default(cuid())
  userId     String
  merchantId String?
  bookingId  String?
  amount     Int      // positif = gagné, négatif = dépensé ou révoqué
  type       String   // EARNED, REVOKED, REDEEMED
  reason     String?  // ex: "Réservation confirmée", "Annulation", "Échange récompense"
  createdAt  DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  merchant Merchant? @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  booking  Booking?  @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([userId, merchantId])
  @@index([bookingId])
  @@map("xp_transactions")
}

model XpReward {
  id          String   @id @default(cuid())
  merchantId  String
  name        String   // ex: "10% de réduction", "Coupe gratuite"
  description String?
  xpCost      Int      // Combien d'XP pour obtenir la récompense
  type        String   @default("DISCOUNT") // DISCOUNT, FREE_SERVICE, GIFT
  value       Float?   // ex: 10 pour 10% de réduction, ou prix du service offert
  isActive    Boolean  @default(true)
  maxUses     Int?     // null = illimité
  usedCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  merchant    Merchant      @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  redemptions XpRedemption[]

  @@index([merchantId, isActive])
  @@map("xp_rewards")
}

model XpRedemption {
  id        String   @id @default(cuid())
  rewardId  String
  userId    String
  code      String   @unique // Code unique pour utiliser la récompense
  status    String   @default("ACTIVE") // ACTIVE, USED, EXPIRED
  usedAt    DateTime?
  expiresAt DateTime?
  createdAt DateTime @default(now())

  reward XpReward @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code])
  @@map("xp_redemptions")
}

// ─────────────────────────────────────────────
// GIFT CARDS / CARTES CADEAUX
// ─────────────────────────────────────────────

model GiftCard {
  id            String    @id @default(cuid())
  code          String    @unique
  amount        Float     // Montant en EUR
  balance       Float     // Solde restant
  currency      String    @default("XPF")
  senderName    String    // Nom de l'acheteur
  senderEmail   String    // Email de l'acheteur
  recipientName String    // Nom du destinataire
  recipientEmail String   // Email du destinataire
  message       String?   // Message personnalisé
  merchantId    String?   // null = valable partout, sinon chez un marchand spécifique
  status        String    @default("ACTIVE") // ACTIVE, USED, EXPIRED, PENDING_PAYMENT
  expiresAt     DateTime  // Date d'expiration (1 an)
  usedAt        DateTime?
  paymentStatus String?   // PENDING, PAID, FAILED (null = pas de paiement requis)
  payzenOrderId String?
  payzenTransId String?
  createdAt     DateTime  @default(now())

  merchant Merchant? @relation(fields: [merchantId], references: [id], onDelete: SetNull)

  @@index([code])
  @@index([recipientEmail])
  @@map("gift_cards")
}

// ─────────────────────────────────────────────
// FAVORITES
// ─────────────────────────────────────────────

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  merchantId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([userId, merchantId])
  @@index([userId])
  @@map("favorites")
}

// ─────────────────────────────────────────────
// PUSH NOTIFICATIONS
// ─────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// ─────────────────────────────────────────────
// PATIENT NOTES (Private notes per merchant)
// ─────────────────────────────────────────────

model PatientNote {
  id         String   @id @default(cuid())
  merchantId String
  clientId   String
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  client   User     @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([merchantId, clientId])
  @@map("patient_notes")
}

// ─────────────────────────────────────────────
// WEBHOOK IDEMPOTENCY
// ─────────────────────────────────────────────

model WebhookEvent {
  id        String   @id
  source    String   // "stripe" or "payzen"
  createdAt DateTime @default(now())

  @@index([source])
  @@map("webhook_events")
}

// ─────────────────────────────────────────────
// REFERRALS / PARRAINAGE
// ─────────────────────────────────────────────

model Referral {
  id          String   @id @default(cuid())
  referrerId  String
  refereeId   String
  status      String   @default("REGISTERED") // REGISTERED, FIRST_BOOKING, COMPLETED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  referrer    User     @relation("ReferralsSent", fields: [referrerId], references: [id], onDelete: Cascade)
  referee     User     @relation("ReferralsReceived", fields: [refereeId], references: [id], onDelete: Cascade)

  @@unique([refereeId])
  @@index([referrerId])
  @@map("referrals")
}
