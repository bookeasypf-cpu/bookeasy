# Database (PostgreSQL — Neon)
DATABASE_URL="postgresql://user:password@host:5432/bookeasy?sslmode=require"

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (Resend)
# EMAIL_FROM domain MUST match a domain verified in Resend Dashboard (DKIM/SPF/DMARC).
# RESEND_WEBHOOK_SECRET is REQUIRED in production — the webhook handler rejects
# unsigned requests to prevent attackers marking users as bounced.
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
EMAIL_FROM="BookEasy <noreply@bookeasy.me>"
SUPPORT_EMAIL=bookeasy.pf@gmail.com

# Marketing — destinataire des notifications de visuels auto-générés
# (signup marchand + upgrade Pro). Fallback sur SUPPORT_EMAIL si absent.
MARKETING_ADMIN_EMAIL=bookeasy.pf@gmail.com

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Patient notes encryption (AES-256-GCM at-rest).
# Required in production — without it, the patient notes API throws on read/write.
# Generate with: openssl rand -base64 32
# Rotation requires re-encrypting all rows; pick once and store in a secret manager.
PATIENT_NOTES_ENC_KEY=

# PayZen (OSB — paiements clients XPF)
PAYZEN_SHOP_ID=
PAYZEN_KEY_TEST=
PAYZEN_KEY_PROD=
PAYZEN_MODE=TEST

# Cron jobs (sécurisation endpoints cron)
CRON_SECRET=

# Vercel Blob (upload de photos profil + couverture marchand)
# Auto-injecté en prod si le Blob store est lié au projet Vercel.
# Pour le dev local : récupérer le token depuis le dashboard Vercel.
BLOB_READ_WRITE_TOKEN=

# Web Push (VAPID keys — générer avec npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Personal command-center dashboard (Mara) — /api/marketing/stats bearer token.
# Generate with: openssl rand -hex 32
# Must match DASHBOARD_API_TOKEN in claude-dashboard/.env.local
DASHBOARD_API_TOKEN=

# Admin key for /api/marketing/posts and /api/marketing/notify-test.
# MUST be distinct from NEXTAUTH_SECRET (which signs every session JWT).
# Compared via timingSafeEqual server-side. Generate: openssl rand -hex 32
ADMIN_API_KEY=

# PostHog analytics (EU host for RGPD).
# Create a project at https://eu.posthog.com — Project API Key goes in
# NEXT_PUBLIC_POSTHOG_KEY. Generate a Personal API Key with query:read
# scope for POSTHOG_API_KEY (used by /api/marketing/stats to fetch the
# funnel via HogQL).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
POSTHOG_API_KEY=
POSTHOG_PROJECT_ID=
