# Database (PostgreSQL — Neon)
DATABASE_URL="postgresql://user:password@host:5432/bookeasy?sslmode=require"

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (Resend)
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
EMAIL_FROM=noreply@bookeasy.pf
SUPPORT_EMAIL=bookeasy.pf@gmail.com

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# PayZen (OSB — paiements clients XPF)
PAYZEN_SHOP_ID=
PAYZEN_KEY_TEST=
PAYZEN_KEY_PROD=
PAYZEN_MODE=TEST

# Cron jobs (sécurisation endpoints cron)
CRON_SECRET=

# Vercel Blob (upload de photos profil + couverture marchand)
# Auto-injecté en prod si le Blob store est lié au projet Vercel.
# Pour le dev local : récupérer le token depuis le dashboard Vercel.
BLOB_READ_WRITE_TOKEN=

# Web Push (VAPID keys — générer avec npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
