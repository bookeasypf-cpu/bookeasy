# Database (PostgreSQL — Neon)
DATABASE_URL="postgresql://user:password@host:5432/bookeasy?sslmode=require"

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@bookeasy.pf

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# PayZen (OSB — paiements clients XPF)
PAYZEN_SHOP_ID=
PAYZEN_KEY_TEST=
PAYZEN_KEY_PROD=
PAYZEN_MODE=TEST

# Stripe (abonnements Pro marchands)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Cron jobs (sécurisation endpoints cron)
CRON_SECRET=

# Web Push (VAPID keys — générer avec npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
